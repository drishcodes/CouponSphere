# --- MongoDB Configuration ---
# Use a local URI or an external one like MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/couponsphere?retryWrites=true&w=majority

# --- Redis Configuration ---
# In Docker Compose, use 'redis://redis:6379'
REDIS_URL=redis://redis:6379

# --- Authentication (JWT) ---
# Generate strong random strings for these in production
JWT_ACCESS_SECRET=your-very-strong-access-secret
JWT_REFRESH_SECRET=your-very-strong-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- CORS & Origin ---
# Comma-separated list of allowed origins
CLIENT_ORIGIN=http://localhost,http://127.0.0.1

# --- Frontend Configuration ---
# The API URL that the browser will use (must be accessible from the user's browser)
VITE_API_URL=http://localhost:5005/api/v1

# --- Microservices ---
# URL for the Fraud Microservice
FRAUD_SERVICE_URL=http://fraud-microservice:8080

# --- Feature Flags ---
SEED_DEMO_DATA=true
MEMORY_DB=false

# --- External Integrations (Optional) ---
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# OPENAI_API_KEY=
